{
  // *** VNTextProxy-only settings (winmm.dll)
  "debugLogging": true,
  // enableFontSubstitution is a global switch to enable/disable all text proxying code in VNTextProxy
  // It should be true if the data files contains English-translated script, false if they contain original Japanese script.
  "enableFontSubstitution": true,
  // Pixels between rows of text. Hardcoded override in script.src (only works in Flyable Heart for now)
  "fontYSpacingBetweenLines": 7,
  // Number of pixels to raise all text upward in the textbox.
  "fontYTopPosDecrease": 4,
  // graphicsMode options:
  //   "raw": original game's rendering
  //   "dx9": upscales to your monitor's native resolution, and corrects aspect ratio for widescreen monitors and DPI scaling.  Automatically downgraded to "raw" if the window aspect ratio is already widescreen.
  //   "dx11": (experimental) adds a sharpening upscaling shader (CuNNy-fast-NVL)
  "graphicsMode": "dx9",

  // *** VNTextPatch-only settings
  // Line width used by VNTextPatch to determine when to insert <br>s in the script.
  "proportionalLineWidth": 545,
  // SoftPAL's runtime maximal line width override. Hardcoded override in script.src (only works in Flyable Heart for now)
  // Generally, we don't want this to ever be reached in the translated script, as it linebreaks character-by-character
  // instead of word-by-word. This value also affects the time it takes to fade-in the text.
  // So this should be slightly larger than proportionalLineWidth.
  "maxLineWidth": 570,
  // Number of lines to trigger a warning in VNTextPatch. Should be 1 above the max number of lines in the textbox.
  "numLinesWarnThreshold": 4,

  // *** Shared text settings
  // Font filename before ".ttf" must be the same as the internal name of the font.
  //
  // Main font. We use the ExtraBold weight because it looks good with the black outlines SoftPal adds around each shape.
  "customFontFilename": "Nunito ExtraBold.ttf",
  "customFontName": "Nunito",
  // Monospace is used in niche situations like messages rendered on a computer within the fiction.
  "monospaceFontFilename": "Inconsolata ExtraBold.ttf",
  "monospaceFontName": "Inconsolata",
  "fontHeightIncrease": 6,
  "translations": {
    "恋×シンアイ彼女": "Koi x Shin Ai Kanojo",
    "環境設定": "Preferences",
    "ｷｬﾝｾﾙ": "Cancel",
    "基本動作": "Basic Settings",
    "非アクティブでも動作する": "Run in Background",
    "非アクティブ( 他のウインドウに隠れる )になっても": "Even if inactive (covered by other windows)",
    "システムは常に動作し続けます。": "The system will keep running.",
    "ウインドウ": "Window",
    "鱁全て表示": "Show All",
    "鱂全て非表示": "Hide All",
    "鱃終了": "Exit",
    "全て表示": "Show All",
    "全て非表示": "Hide All",
    "終了": "Exit"
  }
}
